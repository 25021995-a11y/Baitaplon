<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="640.0" prefHeight="640.0" spacing="0" styleClass="root"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.bidcycle.controller.ProductDetailController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <!-- Header -->
    <HBox prefHeight="54" alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #100820; -fx-border-color: transparent transparent #2d1857 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 20;">
        <Label text="🏷️" style="-fx-font-size: 20px;" />
        <Label fx:id="lblProductName" text="Tên sản phẩm"
               style="-fx-text-fill: #c77dff; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="✕  Đóng" onAction="#onClose"
                style="-fx-background-color: #2d1857; -fx-text-fill: #c77dff; -fx-background-radius: 8; -fx-cursor: hand;" />
    </HBox>

    <!-- Content -->
    <HBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 20; -fx-background-color: #0d0818;">

        <!-- Image panel -->
        <VBox spacing="10" alignment="TOP_CENTER" prefWidth="220"
              style="-fx-background-color: #160c2a; -fx-border-color: #2d1857; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 16;">
            <Label text="Ảnh sản phẩm" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
            <ImageView fx:id="productImage" fitWidth="180" fitHeight="180" preserveRatio="true" visible="false" />
            <Label fx:id="lblNoImage" text="📷\nChưa có ảnh"
                   style="-fx-text-fill: #3a2550; -fx-font-size: 13px; -fx-text-alignment: center;" visible="true" />
            <Region prefHeight="10" />
            <Label text="Người bán" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
            <Label fx:id="lblSeller" text="—" style="-fx-text-fill: #9d4edd; -fx-font-size: 13px;" />
        </VBox>

        <!-- Info panel -->
        <VBox spacing="14" VBox.vgrow="ALWAYS">
            <!-- Price + time -->
            <HBox spacing="20">
                <VBox spacing="4"
                      style="-fx-background-color: #160c2a; -fx-border-color: #2d1857; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 16 12 16;">
                    <Label text="💰 Giá hiện tại" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
                    <Label fx:id="lblCurrentPrice" text="—"
                           style="-fx-text-fill: #00e676; -fx-font-size: 20px; -fx-font-weight: bold;" />
                </VBox>
                <VBox spacing="4"
                      style="-fx-background-color: #160c2a; -fx-border-color: #2d1857; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 16 12 16;">
                    <Label text="⏱️ Thời gian còn lại" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
                    <Label fx:id="lblTimeLeft" text="—"
                           style="-fx-text-fill: #ffcc00; -fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
                <VBox spacing="4"
                      style="-fx-background-color: #160c2a; -fx-border-color: #2d1857; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 16 12 16;">
                    <Label text="🏆 Đang dẫn đầu" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
                    <Label fx:id="lblTopBidder" text="—"
                           style="-fx-text-fill: #c77dff; -fx-font-size: 14px; -fx-font-weight: bold;" />
                </VBox>
            </HBox>

            <!-- Description -->
            <VBox spacing="6"
                  style="-fx-background-color: #1a1030; -fx-border-color: #3d2070; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 14 16 14 16;">
                <Label text="📝  Mô tả sản phẩm" style="-fx-text-fill: #d4a8ff; -fx-font-size: 12px; -fx-font-weight: bold;" />
                <Label fx:id="lblDescription" text="Không có mô tả."
                       style="-fx-text-fill: #e8d8ff; -fx-font-size: 13px; -fx-wrap-text: true; -fx-background-color: transparent;"
                       wrapText="true" maxWidth="320" />
            </VBox>

            <!-- Live price indicator canvas -->
            <VBox spacing="4"
                  style="-fx-background-color: #160c2a; -fx-border-color: #2d1857; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12 10 12;">
                <Label text="📈  Giá trực tiếp" style="-fx-text-fill: #5a3d7a; -fx-font-size: 11px;" />
                <Canvas fx:id="priceChartCanvas" width="300" height="50" />
            </VBox>

            <!-- Bid History Real-time Line Chart -->
            <VBox spacing="6"
                  style="-fx-background-color: #0f0820; -fx-border-color: #3d1d6e; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-width: 1; -fx-padding: 14 14 14 14;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📊  Bid History — Real-time Price Curve"
                           style="-fx-text-fill: #c77dff; -fx-font-size: 12px; -fx-font-weight: bold;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblBidCount" text="0 bids"
                           style="-fx-text-fill: #4a3060; -fx-font-size: 10px;" />
                </HBox>
                <Canvas fx:id="bidHistoryCanvas" width="330" height="130" />
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="1">
                        <Label text="GIÁ CAO NHẤT" style="-fx-text-fill: #4a3060; -fx-font-size: 9px; -fx-font-weight: bold;" />
                        <Label fx:id="lblPeakPrice" text="—"
                               style="-fx-text-fill: #00e5b0; -fx-font-size: 12px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="1">
                        <Label text="GIÁ KHỞI ĐIỂM" style="-fx-text-fill: #4a3060; -fx-font-size: 9px; -fx-font-weight: bold;" />
                        <Label fx:id="lblStartPrice" text="—"
                               style="-fx-text-fill: #6a4a8a; -fx-font-size: 12px; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="1">
                        <Label text="TĂNG" style="-fx-text-fill: #4a3060; -fx-font-size: 9px; -fx-font-weight: bold;" />
                        <Label fx:id="lblPriceIncrease" text="—"
                               style="-fx-text-fill: #ffcc00; -fx-font-size: 12px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
