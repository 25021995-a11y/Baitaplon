<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="900.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baitaplon.baitaplon.SellerController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <children>
        <AnchorPane maxHeight="550.0" maxWidth="750.0" prefHeight="550.0" prefWidth="750.0">
            <children>

                <Label alignment="CENTER" layoutX="175.0" layoutY="20.0" prefWidth="400.0" styleClass="header-label" text="SELLER DASHBOARD" textFill="#9d4edd">
                    <font>
                        <Font name="Segoe UI Bold" size="26.0" />
                    </font>
                </Label>

                <Label layoutX="560.0" layoutY="20.0" text="Username:" textFill="#cbb2ff">
                    <font><Font name="Segoe UI Semibold" size="13.0" /></font>
                </Label>
                <Label fx:id="userName" layoutX="630.0" layoutY="20.0" prefHeight="18.0" prefWidth="100.0" textFill="#00ffcc">
                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                </Label>

                <Label layoutX="560.0" layoutY="45.0" text="Wallet:" textFill="#cbb2ff">
                    <font><Font name="Segoe UI Semibold" size="13.0" /></font>
                </Label>
                <Label fx:id="Wallet" layoutX="630.0" layoutY="45.0" prefHeight="18.0" prefWidth="100.0" textFill="#00ffcc">
                    <font><Font name="Segoe UI Bold" size="13.0" /></font>
                </Label>

                <TableView fx:id="sellerTable" layoutX="40.0" layoutY="90.0" prefHeight="240.0" prefWidth="670.0">
                    <columns>
                        <TableColumn fx:id="colName" prefWidth="200.0" text="Sản phẩm" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Giá gốc" />
                        <TableColumn fx:id="colTime" prefWidth="160.0" text="Thời gian" />
                        <TableColumn fx:id="topBidColumn" prefWidth="158.0" text="Top Bid" />
                    </columns>
                </TableView>

                <Label layoutX="40.0" layoutY="350.0" text="Tên sản phẩm (Name)">
                    <font><Font name="Segoe UI Semibold" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtProductName" layoutX="40.0" layoutY="375.0" prefHeight="40.0" prefWidth="220.0" promptText="Nhập tên sản phẩm..." />

                <Label layoutX="280.0" layoutY="350.0" text="Giá khởi điểm (Price)">
                    <font><Font name="Segoe UI Semibold" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtPrice" layoutX="280.0" layoutY="375.0" prefHeight="40.0" prefWidth="150.0" promptText="Giá gốc..." />

                <Label layoutX="450.0" layoutY="350.0" text="Thời gian (Time)">
                    <font><Font name="Segoe UI Semibold" size="13.0" /></font>
                </Label>
                <TextField fx:id="txtTime" layoutX="450.0" layoutY="375.0" prefHeight="40.0" prefWidth="150.0" promptText="Thời gian đấu giá..." />

                <Button layoutX="40.0" layoutY="450.0" mnemonicParsing="false" onAction="#onSellButtonClick" prefHeight="45.0" prefWidth="180.0" text="Thêm lên sàn (Sell)" />

                <Button fx:id="refreshButton" layoutX="240.0" layoutY="450.0" mnemonicParsing="false" onAction="#onRefreshButtonClick" prefHeight="45.0" prefWidth="120.0" style="-fx-background-color: #4a2d6e;" text="Refresh" />

                <Label fx:id="statusLabel" alignment="CENTER" layoutX="40.0" layoutY="510.0" prefHeight="20.0" prefWidth="670.0" textFill="#ffcc00">
                    <font><Font name="Segoe UI Italic" size="14.0" /></font>
                </Label>

            </children>
        </AnchorPane>
    </children>
</StackPane>