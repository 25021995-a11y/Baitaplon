<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baitaplon.baitaplon.Inventory">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <children>
        <AnchorPane maxHeight="500.0" maxWidth="600.0" prefHeight="500.0" prefWidth="600.0">
            <children>

                <Label alignment="CENTER" layoutX="150.0" layoutY="35.0" prefWidth="300.0" styleClass="header-label" text="INVENTORY" textFill="#9d4edd">
                    <font>
                        <Font name="Segoe UI Bold" size="32.0" />
                    </font>
                </Label>

                <Label alignment="CENTER" layoutX="150.0" layoutY="90.0" prefWidth="300.0" text="Danh sách các sản phẩm bạn đã đấu giá thành công" textFill="#cbb2ff">
                    <font>
                        <Font name="Segoe UI Italic" size="13.0" />
                    </font>
                </Label>

                <TableView fx:id="inventoryTable" layoutX="80.0" layoutY="130.0" prefHeight="280.0" prefWidth="440.0">
                    <columns>
                        <TableColumn fx:id="ProductColumn" prefWidth="240.0" text="Sản phẩm" />
                        <TableColumn fx:id="PriceColumn" prefWidth="198.0" text="Giá mua vào" />
                    </columns>
                </TableView>

                <Button fx:id="backToMain" layoutX="200.0" layoutY="430.0" mnemonicParsing="false" onAction="#backToMainButtonClick" prefHeight="40.0" prefWidth="200.0" styleClass="link-button" text="Quay lại màn hình chính" />

            </children>
        </AnchorPane>
    </children>
</StackPane>