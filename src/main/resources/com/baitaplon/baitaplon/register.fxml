<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baitaplon.baitaplon.Register">

   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>

   <children>
      <AnchorPane maxHeight="520.0" maxWidth="600.0" prefHeight="520.0" prefWidth="600.0">
         <children>

            <Label layoutX="145.0" layoutY="30.0" styleClass="header-label" text="CREATE ACCOUNT" textFill="#9d4edd">
               <font>
                  <Font name="Segoe UI Bold" size="32.0" />
               </font>
            </Label>

            <Label layoutX="120.0" layoutY="115.0" text="Username">
               <font>
                  <Font name="Segoe UI Semibold" size="14.0" />
               </font>
            </Label>
            <TextField fx:id="regUsernameField" layoutX="230.0" layoutY="108.0" prefHeight="35.0" prefWidth="250.0" promptText="Enter your name..." />

            <Label layoutX="120.0" layoutY="175.0" text="Password">
               <font>
                  <Font name="Segoe UI Semibold" size="14.0" />
               </font>
            </Label>
            <PasswordField fx:id="regPasswordField" layoutX="230.0" layoutY="168.0" prefHeight="35.0" prefWidth="250.0" promptText="Create a password..." />

            <Label layoutX="120.0" layoutY="235.0" text="Confirm Pass">
               <font>
                  <Font name="Segoe UI Semibold" size="14.0" />
               </font>
            </Label>
            <PasswordField fx:id="regConfirmPasswordField" layoutX="230.0" layoutY="228.0" prefHeight="35.0" prefWidth="250.0" promptText="Confirm your password..." />

            <Label layoutX="120.0" layoutY="295.0" text="Role">
               <font>
                  <Font name="Segoe UI Semibold" size="14.0" />
               </font>
            </Label>
            <ComboBox fx:id="roleComboBox" layoutX="230.0" layoutY="288.0" prefHeight="35.0" prefWidth="250.0" promptText="Select your role..." />

            <Button layoutX="175.0" layoutY="360.0" mnemonicParsing="false" onAction="#onRegisterSubmit" prefHeight="40.0" prefWidth="250.0" text="REGISTER" />

            <Label fx:id="regStatusLabel" alignment="CENTER" layoutX="100.0" layoutY="415.0" prefHeight="20.0" prefWidth="400.0" textAlignment="CENTER" textFill="#ff6b6b">
               <font>
                  <Font name="Segoe UI Italic" size="13.0" />
               </font>
            </Label>

            <Button layoutX="245.0" layoutY="450.0" mnemonicParsing="false" onAction="#onBackToLogin" styleClass="link-button" text="Return to Login" />

         </children>
      </AnchorPane>
   </children>
</StackPane>